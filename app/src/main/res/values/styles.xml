<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 읽기 전용 작은 별점 (목록/카드용) -->
    <style name="RatingBar.Amber.Small" parent="Widget.AppCompat.RatingBar.Small">
        <item name="android:progressDrawable">@drawable/ratingbar_amber_sm</item>
        <item name="android:isIndicator">true</item>
        <item name="android:numStars">5</item>
        <item name="android:stepSize">0.1</item>
    </style>

    <!-- 입력용 별점 (리뷰 작성) -->
    <style name="RatingBar.Amber.Input" parent="Widget.AppCompat.RatingBar">
        <item name="android:progressDrawable">@drawable/ratingbar_amber</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:maxHeight">36dp</item>
        <item name="android:isIndicator">false</item>
        <item name="android:numStars">5</item>
        <item name="android:stepSize">1</item>
    </style>
</resources>
