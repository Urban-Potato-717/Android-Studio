<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="@dimen/card_padding"
    android:layout_marginBottom="@dimen/card_gap">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvNickname"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="닉네임"
            android:textColor="@color/text_title"
            android:textSize="15sp"
            android:textStyle="bold" />

        <RatingBar
            android:id="@+id/rbRating"
            style="@style/RatingBar.Amber.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:rating="5" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="2026.05.12"
        android:textColor="@color/text_sub"
        android:textSize="@dimen/text_sub" />

    <!-- 일반 내용 -->
    <LinearLayout
        android:id="@+id/groupContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="한줄평"
            android:textColor="@color/text_body"
            android:textSize="@dimen/text_body" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_thumb_up"
                android:contentDescription="@string/helpful_format" />
            <TextView
                android:id="@+id/tvHelpful"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="도움돼요 0"
                android:textColor="@color/text_sub"
                android:textSize="@dimen/text_sub" />
        </LinearLayout>
    </LinearLayout>

    <!-- 스포일러 블라인드 -->
    <LinearLayout
        android:id="@+id/groupSpoiler"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_spoiler"
        android:padding="16dp"
        android:visibility="gone">
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_warning"
            android:contentDescription="@string/spoiler_blinded" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/spoiler_blinded"
            android:textColor="@color/spoiler_red"
            android:textSize="@dimen/text_body" />
    </LinearLayout>
</LinearLayout>
